#       -acid_ksp_rtol 1e-3 \
#       > coarse_agglomerate_frac_perm_test_log 2>&1


stdbuf -oL -eL mpiexec -n 128 --oversubscribe ./release/LeachingSim_uint8 \
       --raw-file LA3_d0_v1_uint8_FRACTURED_WIDE_169_169_142.raw \
       --xext 169 \
       --yext 169 \
       --zext 142 \
       --csat 1.0 \
       --theta 1.0 \
       --dt 3600.0 \
       --tmax 1728000.0 \
       --use_out_time true \
       --out_time 60.0 \
       --D 0.0000001 \
       --kreac 0.1 \
       --voxel_size 0.000034 \
       --top_pressure 0.1 \
       --evap_flux 0.0 \
       --implicit_sat true \
       --max_cap_grad 1000.0 \
       --enable_microporosity true \
       --rock_D_fac 0.001 \
       --time_scalar 50.0 \
       --debug true \
       --out_dir ./coarse_agglomerate_frac_perm_test_output \
       -press_pc_type hypre \
       -press_pc_hypre_type boomeramg \
       -sat_pc_type bjacobi \
       -sat_sub_pc_type ilu \
       -sat_sub_pc_factor_shift_type NONZERO \
       -conc_pc_type bjacobi \
       -conc_sub_pc_type ilu \
       -conc_sub_pc_factor_shift_type NONZERO \
       -acid_pc_type bjacobi \
       -acid_sub_pc_type ilu \
       -acid_sub_pc_factor_shift_type NONZERO \
       -conc_ksp_rtol 1e-2 \
       -acid_ksp_rtol 1e-2 \
       -sat_ksp_rtol 1e-2 \
       > coarse_agglomerate_frac_perm_test_log 2>&1